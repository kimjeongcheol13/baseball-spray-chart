}

function recSB(ok){
  showToast(ok?'도루 성공 기록':'도루 실패 기록',false);
}

function chRbi(d){S.rbi=Math.max(0,S.rbi+d);document.getElementById('rbiVal').textContent=S.rbi}

// ==================== DOTS ====================
const RC={
  '안타':'#2dd4a0','내야안타':'#5eead4',
  '2루타':'#4b8cf5','3루타':'#f6c23e','홈런':'#f56565',
  '플라이 아웃':'#374151','땅볼 아웃':'#2a3040'
};
function drawDot(r){
  if(!r.x)return;
  const x=r.x*FS,y=r.y*FS;
  const col=RC[r.res]||'#94a3b8';
  const out=r.res.includes('아웃');
  hCtx.beginPath();hCtx.arc(x,y,out?4:6.5,0,Math.PI*2);
  hCtx.fillStyle=col+'bb';hCtx.fill();
  hCtx.strokeStyle=col;hCtx.lineWidth=1.5;hCtx.stroke();
  if(!out){
    hCtx.beginPath();hCtx.arc(x,y,11,0,Math.PI*2);
    hCtx.strokeStyle=col+'33';hCtx.lineWidth=2;hCtx.stroke();
  }
}
function redrawHits(){
  if(!hCtx)return;
  hCtx.clearRect(0,0,FS,FS);
  S.abs.forEach(a=>{if(a.x)drawDot(a)});
}

// ==================== UPDATE ====================
function updateAll(){
  renderLP();renderMob();renderRecs();updStats();
  document.getElementById('innDisp').textContent=document.getElementById('innSel').value;
}

function renderRecs(){
  const el=document.getElementById('recList');
  document.getElementById('recCnt').textContent=S.abs.length+'개 기록';
  if(!S.abs.length){
    el.innerHTML='<div style="text-align:center;padding:28px 0;color:var(--text3);font-size:11px">타석을 기록하면<br>여기에 표시됩니다</div>';
    return;
  }
  const BC={
    '안타':'b-hit','내야안타':'b-hit',
    '2루타':'b-2b','3루타':'b-3b','홈런':'b-hr',
    '볼넷':'b-walk','사구':'b-hbp',
    '삼진':'b-k','플라이 아웃':'b-out','땅볼 아웃':'b-out',
    '희타':'b-other','희비':'b-other','병살':'b-out'
  };
  el.innerHTML=[...S.abs].reverse().map(a=>`
    <div class="rec-item">
      <span class="badge ${BC[a.res]||'b-other'}">${a.res}</span>
      <div class="rec-info">
        <div class="rec-player">#${a.bnum} ${a.bname}</div>
        <div class="rec-detail">${a.inn}${a.pt?' · '+a.pt:''}${a.dir?' · '+a.dir:''}${a.rbi>0?' · '+a.rbi+'타점':''} · ${a.ts}</div>
      </div>
      <button class="rec-del" onclick="delRec(${a.id})">✕</button>
    </div>`).join('');
}

function delRec(id){
  S.abs=S.abs.filter(a=>a.id!==id);
  redrawHits();updateAll();
}
function undoLast(){
  if(!S.abs.length)return;
  S.abs.pop();redrawHits();updateAll();hideToast();
}
function clearAll(){
  if(!confirm('모든 타석 기록을 삭제할까요?'))return;
  S.abs=[];S.totalRBI=0;
  hCtx&&hCtx.clearRect(0,0,FS,FS);updateAll();
}

// ==================== STATS ====================
function updStats(){
  const abs=S.abs;
  const hits=['안타','내야안타','2루타','3루타','홈런'];
  const base={'안타':1,'내야안타':1,'2루타':2,'3루타':3,'홈런':4};
  const noab=['볼넷','사구','희타','희비'];
  const oab=abs.filter(a=>!noab.includes(a.res)).length;
  const h=abs.filter(a=>hits.includes(a.res)).length;
  const reach=abs.filter(a=>[...hits,'볼넷','사구'].includes(a.res)).length;
  const tb=abs.reduce((s,a)=>s+(base[a.res]||0),0);
  const rbi=abs.reduce((s,a)=>s+a.rbi,0);
  const avg=oab?h/oab:null;
  const obp=abs.length?reach/abs.length:null;
  const slg=oab?tb/oab:null;
  document.getElementById('sAVG').textContent=avg!=null?avg.toFixed(3).replace('0.','.'):'.---';
  document.getElementById('sOBP').textContent=obp!=null?obp.toFixed(3).replace('0.','.'):'.---';
  document.getElementById('sSLG').textContent=slg!=null?slg.toFixed(3).replace('0.','.'):'.---';
  document.getElementById('sAB').textContent=oab;
  document.getElementById('sH').textContent=h;
  document.getElementById('sRBI').textContent=rbi;

  // Direction
  const fd=abs.filter(a=>a.deg!=null);
  const tot=fd.length||1;
  const pull=fd.filter(a=>a.deg<72).length;
  const ctr=fd.filter(a=>a.deg>=72&&a.deg<=108).length;
  const oppo=fd.filter(a=>a.deg>108).length;
  const pp=Math.round(pull/tot*100),pc=Math.round(ctr/tot*100),po=Math.round(oppo/tot*100);
  document.getElementById('dPull').textContent=pp+'%';
  document.getElementById('dCtr').textContent=pc+'%';
  document.getElementById('dOppo').textContent=po+'%';
  document.getElementById('bPull').style.height=Math.max(3,pp*0.44)+'px';
  document.getElementById('bCtr').style.height=Math.max(3,pc*0.44)+'px';
  document.getElementById('bOppo').style.height=Math.max(3,po*0.44)+'px';

  drawDonut();renderPsTable();
}

function drawDonut(){
  const c=document.getElementById('donut'),ctx=c.getContext('2d');
  const dpr=window.devicePixelRatio||1;
  c.width=72*dpr;c.height=72*dpr;c.style.width='72px';c.style.height='72px';ctx.scale(dpr,dpr);
  const cts={안타:0,'2루타':0,'3루타':0,홈런:0,아웃:0};
  S.abs.forEach(a=>{
    if(['안타','내야안타'].includes(a.res)) cts['안타']++;
    else if(a.res==='2루타') cts['2루타']++;
    else if(a.res==='3루타') cts['3루타']++;
    else if(a.res==='홈런') cts['홈런']++;
    else if(a.res.includes('아웃')||a.res==='병살') cts['아웃']++;
  });
  const cols=['#2dd4a0','#4b8cf5','#f6c23e','#f56565','#374151'];
  const keys=Object.keys(cts);
  const tot=Object.values(cts).reduce((a,b)=>a+b,0);
  const cx=36,cy=36,r=28,ir=16;
  ctx.clearRect(0,0,72,72);
  if(!tot){
    ctx.beginPath();ctx.arc(cx,cy,r,0,Math.PI*2);
    ctx.strokeStyle='#1c1c26';ctx.lineWidth=r-ir;ctx.stroke();
  } else {
    let st=-Math.PI/2;
    keys.forEach((k,i)=>{
      const sl=(cts[k]/tot)*Math.PI*2;
      if(!sl)return;
      ctx.beginPath();ctx.moveTo(cx,cy);ctx.arc(cx,cy,r,st,st+sl);ctx.closePath();
      ctx.fillStyle=cols[i];ctx.fill();st+=sl;
    });
    ctx.beginPath();ctx.arc(cx,cy,ir,0,Math.PI*2);
    ctx.fillStyle='#18181f';ctx.fill();
  }
  const ids=['lp1','lp2','lp3','lp4','lp5'];
  keys.forEach((k,i)=>{
    const pct=tot?Math.round(cts[k]/tot*100):0;
    document.getElementById(ids[i]).textContent=pct+'%';
  });
}

function renderPsTable(){
  const el=document.getElementById('psTable');
  if(!S.lineup.length){el.innerHTML='<div style="font-size:11px;color:var(--text3);text-align:center;padding:8px">선수를 추가하세요</div>';return}
  const noab=['볼넷','사구','희타','희비'];
  const hits=['안타','내야안타','2루타','3루타','홈런'];
  el.innerHTML=S.lineup.map(p=>{
    const pAbs=S.abs.filter(a=>a.bid===p.id);
    const oab=pAbs.filter(a=>!noab.includes(a.res)).length;
    const h=pAbs.filter(a=>hits.includes(a.res)).length;
    const av=oab?(h/oab).toFixed(3).replace('0.','.'):'.---';
    const rbi=pAbs.reduce((s,a)=>s+a.rbi,0);
    return`<div class="ps-row">
      <div class="ps-num">${p.num}</div>
      <div class="ps-name">${p.name}</div>
      <div class="ps-avg">${av}</div>
      <div class="ps-ab">${h}H/${oab}AB${rbi>0?' '+rbi+'타점':''}</div>
    </div>`;
  }).join('');
}

// ==================== TABS ====================
function swTab(name,el){
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('on'));
  document.querySelectorAll('.tab-pnl').forEach(p=>p.classList.remove('on'));
  el.classList.add('on');
  document.getElementById('pnl-'+name).classList.add('on');
  if(name==='stat')updStats();
}

// ==================== OVERLAYS ====================
function openOverlay(id){document.getElementById(id).classList.add('show')}
function closeOverlay(id){
  document.getElementById(id).classList.remove('show');
  if(id==='hitOverlay'){oC.classList.remove('show');oCtx&&oCtx.clearRect(0,0,FS,FS);S.pending=null}
}
function closeHit(){closeOverlay('hitOverlay')}

// ==================== TOAST ====================
let _tt;
function showToast(msg,showUndo=true,autoHide=true){
  const t=document.getElementById('toast');
  document.getElementById('toastTxt').textContent=msg;
  document.getElementById('toastUndo').style.display=showUndo?'':'none';
  t.classList.add('show');clearTimeout(_tt);
  if(autoHide) _tt=setTimeout(hideToast,3000);
}
function hideToast(){document.getElementById('toast').classList.remove('show')}

// ==================== SAVE / LOAD ====================
function saveGame(){
  const key='sl_'+Date.now();
  const data={
    key,hs:S.hs,as:S.as,
    th:document.getElementById('tHome').value,
    ta:document.getElementById('tAway').value,
    lineup:S.lineup,abs:S.abs,
    d:new Date().toLocaleDateString('ko-KR'),
    ts:new Date().toLocaleString('ko-KR')
  };
  const saves=JSON.parse(localStorage.getItem('sl_saves')||'[]');
  saves.push({key,label:`${data.d} ${data.th} ${data.hs}:${data.as} ${data.ta}`,ts:data.ts});
  localStorage.setItem('sl_saves',JSON.stringify(saves));
  localStorage.setItem(key,JSON.stringify(data));
  showToast('경기 저장 완료 ✓',false);
}

function openLoad(){
  const saves=JSON.parse(localStorage.getItem('sl_saves')||'[]');
  const el=document.getElementById('saveList');
  if(!saves.length){
    el.innerHTML='<div style="text-align:center;padding:20px;color:var(--text3);font-size:12px">저장된 경기가 없습니다</div>';
  } else {
    el.innerHTML=[...saves].reverse().map(s=>`
      <div class="load-item" onclick="restoreGame('${s.key}')">
        <div class="load-item-title">${s.label}</div>
        <div class="load-item-date">${s.ts}</div>
      </div>`).join('');
  }
  openOverlay('loadOverlay');
}

function restoreGame(key){
  const d=JSON.parse(localStorage.getItem(key));
  if(!d)return;
  document.getElementById('tHome').value=d.th;
  document.getElementById('tAway').value=d.ta;
  S.hs=d.hs;S.as=d.as;
  document.getElementById('scH').textContent=d.hs;
  document.getElementById('scA').textContent=d.as;
  S.lineup=d.lineup;S.abs=d.abs;S.batter=null;
  closeOverlay('loadOverlay');
  redrawHits();updateAll();
  showToast('경기 불러오기 완료',false);
}

// ==================== KEYBOARD ====================
document.addEventListener('keydown',e=>{
  if(e.key==='Escape'){closeHit();closeOverlay('loadOverlay')}
  if((e.ctrlKey||e.metaKey)&&e.key==='z'){e.preventDefault();undoLast()}
});

// ==================== INIT ====================
document.addEventListener('DOMContentLoaded',()=>{
  initCanvas();drawDonut();
  if(localStorage.getItem('sl_visited')) document.getElementById('obOverlay').style.display='none';
  else localStorage.setItem('sl_visited','1');
  document.getElementById('innSel').addEventListener('change',()=>{
    document.getElementById('innDisp').textContent=document.getElementById('innSel').value;
  });
});
</script>
