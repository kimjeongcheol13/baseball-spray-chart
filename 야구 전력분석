<script>
// ==================== STATE ====================
const S = {
  hs:0, as:0,
  lineup:[],
  batter:null,
  abs:[],
  pt:null, zone:null,
  rbi:0,
  pending:null,
  totalRBI:0
};

// ==================== ONBOARDING ====================
const OB = [
  {icon:'⚾',step:'시작하기 · 1 / 3',title:'SprayLab에 오신 걸\n환영합니다',desc:'타석을 기록하고, 패턴을 발견하세요.\n사회인야구를 위한 가장 쉬운 데이터 분석 툴입니다.'},
  {icon:'🏟️',step:'기록 방법 · 2 / 3',title:'3단계로 타석을\n기록하세요',desc:'① 좌측 라인업에서 타자 선택\n② 투구 종류 · 코스 선택 (선택사항)\n③ 필드를 클릭 → 타구 결과 선택\n\n볼넷·삼진은 하단 버튼으로 즉시 기록'},
  {icon:'📊',step:'통계 분석 · 3 / 3',title:'통계가 자동으로\n쌓입니다',desc:'당겨치기/밀어치기 비율, 타율, OBP, SLG가\n자동 계산됩니다.\n오른쪽 [통계] 탭에서 확인하세요.\n\n경기를 저장하면 다음에도 이어서 사용할 수 있습니다.'}
];
let obIdx=0;
function obNext(){
  obIdx++;
  if(obIdx>=OB.length){document.getElementById('obOverlay').style.display='none';return}
  const o=OB[obIdx];
  document.getElementById('obIcon').textContent=o.icon;
  document.getElementById('obStep').textContent=o.step;
  document.getElementById('obTitle').innerHTML=o.title.replace(/\n/g,'<br>');
  document.getElementById('obDesc').innerHTML=o.desc.replace(/\n/g,'<br>');
  for(let i=0;i<3;i++) document.getElementById('d'+i).classList.toggle('on',i===obIdx);
  if(obIdx===2) document.getElementById('obBtn').textContent='시작하기 →';
}

// ==================== SCORE ====================
function chSc(t,d){
  if(t==='h'){S.hs=Math.max(0,S.hs+d);document.getElementById('scH').textContent=S.hs}
  else{S.as=Math.max(0,S.as+d);document.getElementById('scA').textContent=S.as}
}

// ==================== LINEUP ====================
function addPlayer(){
  const n=document.getElementById('pName').value.trim();
  const num=document.getElementById('pNum').value.trim()||(S.lineup.length+1)+'';
  if(!n)return;
  const p={id:Date.now(),name:n,num};
  S.lineup.push(p);
  document.getElementById('pName').value='';
  document.getElementById('pNum').value='';
  renderLP();
  renderMob();
  if(S.lineup.length===1) selBatter(p.id);
}

function selBatter(id){
  S.batter=S.lineup.find(p=>p.id===id)||null;
  renderLP();renderMob();
  const d=document.getElementById('batterDisp');
  if(S.batter) d.innerHTML=`<span class="batter-display"><svg width="10" height="10" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M6 20v-2a6 6 0 0 1 12 0v2"/></svg>#${S.batter.num} ${S.batter.name}</span>`;
  else d.innerHTML='<span class="batter-empty">← 타자를 선택하세요</span>';
}

function delPlayer(id,e){
  e.stopPropagation();
  S.lineup=S.lineup.filter(p=>p.id!==id);
  if(S.batter&&S.batter.id===id) selBatter(null);
  renderLP();renderMob();
}

function renderLP(){
  const el=document.getElementById('lpList');
  document.getElementById('lpCount').textContent=S.lineup.length+'명';
  if(!S.lineup.length){
    el.innerHTML='<div style="padding:20px;text-align:center;color:var(--text3);font-size:11px;line-height:1.6">아래에서 선수를 추가하고<br>타자를 선택하세요</div>';
    return;
  }
  el.innerHTML=S.lineup.map(p=>{
    const pAbs=S.abs.filter(a=>a.bid===p.id);
    const noab=['볼넷','사구','희타','희비'];
    const oab=pAbs.filter(a=>!noab.includes(a.res)).length;
    const h=pAbs.filter(a=>['안타','2루타','3루타','홈런','내야안타'].includes(a.res)).length;
    const av=oab>0?(h/oab).toFixed(3).replace('0.','.'):'.---';
    const on=S.batter&&S.batter.id===p.id;
    return`<div class="player-row${on?' active':''}" onclick="selBatter(${p.id})">
      <span class="p-num">${p.num}</span>
