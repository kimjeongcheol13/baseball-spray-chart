<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>SprayLab — 타구를 분석하다</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;600;700;900&family=JetBrains+Mono:wght@400;600;700&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #09090f;
  --bg-card: #111118;
  --bg-raised: #18181f;
  --bg-hover: #1e1e27;
  --accent: #4b8cf5;
  --accent-dim: rgba(75,140,245,0.12);
  --accent-dim2: rgba(75,140,245,0.06);
  --green: #2dd4a0;
  --red: #f56565;
  --yellow: #f6c23e;
  --orange: #fb923c;
  --purple: #a78bfa;
  --text: #eef0f8;
  --text2: #8892a4;
  --text3: #434c5e;
  --border: #1c1c26;
  --border2: #252532;
  --shadow: 0 8px 32px rgba(0,0,0,0.5);
  --r: 10px;
  --r2: 14px;
  --font: 'Noto Sans KR', sans-serif;
  --mono: 'JetBrains Mono', monospace;
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html,body{height:100%;background:var(--bg);color:var(--text);font-family:var(--font);overflow:hidden}

/* SCROLLBAR */
::-webkit-scrollbar{width:3px;height:3px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px}

/* HEADER */
.hdr{
  display:flex;align-items:center;justify-content:space-between;
  padding:0 16px;height:52px;
  background:var(--bg-card);border-bottom:1px solid var(--border);
  position:relative;z-index:50;flex-shrink:0;gap:12px;
}
.brand{display:flex;align-items:center;gap:9px;flex-shrink:0}
.brand svg{width:28px;height:28px}
.brand-name{font-size:17px;font-weight:900;letter-spacing:-0.5px;color:var(--text)}
.brand-name em{color:var(--accent);font-style:normal}
.brand-tag{font-size:10px;color:var(--text3);letter-spacing:0.5px;margin-top:1px}

/* SCOREBOARD */
.scoreboard{
  display:flex;align-items:center;gap:10px;
  background:var(--bg-raised);border:1px solid var(--border2);
  border-radius:var(--r);padding:6px 12px;flex-shrink:0;
}
.team-blk{display:flex;align-items:center;gap:6px}
.team-inp{
  background:none;border:none;color:var(--text);font-family:var(--font);
  font-size:12px;font-weight:700;width:56px;text-align:center;outline:none;
  cursor:pointer;
}
.team-inp:focus{background:var(--bg-hover);border-radius:4px}
.sc-ctrl{display:flex;align-items:center;gap:5px}
.sc-btn{
  width:22px;height:22px;border:1px solid var(--border2);background:var(--bg-card);
  color:var(--text2);border-radius:5px;cursor:pointer;font-size:13px;
  display:flex;align-items:center;justify-content:center;
  transition:all 90ms;font-family:var(--mono);line-height:1;
}
.sc-btn:hover{border-color:var(--accent);color:var(--accent)}
.sc-btn:active{transform:scale(0.88)}
.sc-val{
  font-family:var(--mono);font-size:20px;font-weight:700;
  min-width:28px;text-align:center;color:var(--text);
}
.vs{font-size:10px;font-weight:800;color:var(--text3);letter-spacing:1px}

.inn-sel{
  background:var(--bg-raised);border:1px solid var(--border2);border-radius:7px;
  padding:5px 8px;color:var(--text2);font-family:var(--font);font-size:12px;
  cursor:pointer;outline:none;
}
.inn-sel option{background:var(--bg-card)}

/* BUTTONS */
.btn{
  display:inline-flex;align-items:center;gap:5px;padding:7px 13px;
  border-radius:8px;font-size:12px;font-weight:700;font-family:var(--font);
  cursor:pointer;transition:all 100ms;border:none;outline:none;white-space:nowrap;
}
.btn:active{transform:scale(0.95)}
.btn-primary{background:var(--accent);color:#fff}
.btn-primary:hover{background:#5d9bff}
.btn-ghost{background:none;border:1px solid var(--border2);color:var(--text2)}
.btn-ghost:hover{border-color:var(--accent);color:var(--accent);background:var(--accent-dim2)}
.btn-red{background:none;border:1px solid var(--red);color:var(--red)}
.btn-red:hover{background:rgba(245,101,101,.1)}
.btn-icon{padding:7px;border-radius:8px}

/* LAYOUT */
.layout{
  display:grid;grid-template-columns:220px 1fr 260px;
  height:calc(100vh - 52px);overflow:hidden;
}

/* LEFT PANEL */
.pnl-left{
  background:var(--bg-card);border-right:1px solid var(--border);
  display:flex;flex-direction:column;overflow:hidden;
}
.pnl-hd{
  padding:10px 14px;border-bottom:1px solid var(--border);
  display:flex;align-items:center;justify-content:space-between;flex-shrink:0;
}
.pnl-title{font-size:10px;font-weight:800;letter-spacing:1.2px;text-transform:uppercase;color:var(--text3)}

.lineup-list{flex:1;overflow-y:auto;padding:6px}
.player-row{
  display:flex;align-items:center;gap:8px;padding:8px 10px;
  border-radius:8px;cursor:pointer;transition:all 100ms;
  border:1px solid transparent;margin-bottom:3px;position:relative;
}
.player-row:hover{background:var(--bg-raised)}
.player-row.active{background:var(--accent-dim);border-color:var(--accent)}
.p-num{font-family:var(--mono);font-size:11px;color:var(--text3);width:18px;text-align:right;flex-shrink:0}
.p-avatar{
  width:28px;height:28px;border-radius:50%;background:var(--bg-hover);
  border:1px solid var(--border2);display:flex;align-items:center;
  justify-content:center;font-size:11px;font-weight:800;color:var(--accent);
  flex-shrink:0;
}
.player-row.active .p-avatar{background:var(--accent);color:#fff;border-color:var(--accent)}
.p-info{flex:1;min-width:0}
.p-name{font-size:12px;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.p-mini{font-size:10px;color:var(--text3);font-family:var(--mono)}
.p-del{
  position:absolute;right:8px;top:50%;transform:translateY(-50%);
  background:none;border:none;color:var(--text3);cursor:pointer;
  font-size:12px;padding:2px 4px;border-radius:4px;opacity:0;transition:all 100ms;
}
.player-row:hover .p-del{opacity:1}
.p-del:hover{color:var(--red)!important;background:rgba(245,101,101,.1)}

.add-row{
  padding:10px;border-top:1px solid var(--border);display:flex;gap:5px;flex-shrink:0;
}
.inp{
  background:var(--bg-raised);border:1px solid var(--border);border-radius:8px;
  padding:7px 10px;color:var(--text);font-family:var(--font);font-size:12px;
  outline:none;transition:border-color 100ms;width:100%;
}
.inp:focus{border-color:var(--accent)}
.inp::placeholder{color:var(--text3)}

/* CENTER PANEL */
.pnl-center{
  display:flex;flex-direction:column;background:var(--bg);overflow:hidden;
}
.batter-bar{
  padding:8px 14px;border-bottom:1px solid var(--border);
  display:flex;align-items:center;justify-content:space-between;gap:8px;
  background:var(--bg-card);flex-shrink:0;
}
.batter-display{font-size:13px;font-weight:700;color:var(--accent);display:flex;align-items:center;gap:6px}
.batter-empty{font-size:12px;color:var(--text3)}
.batter-hint{font-size:11px;color:var(--text3)}

.field-wrap{
  flex:1;display:flex;align-items:center;justify-content:center;
  padding:12px;position:relative;overflow:hidden;
}
.canvas-wrap{
  position:relative;
  width:min(440px, calc(100vh - 220px));
  max-width:100%;
  aspect-ratio:1;
  cursor:crosshair;
}
#fldCanvas,#hitCanvas,#ovrCanvas{
  position:absolute;top:0;left:0;width:100%;height:100%;
}
#ovrCanvas{pointer-events:none;opacity:0;transition:opacity 150ms}
#ovrCanvas.show{opacity:1}
#hitCanvas{pointer-events:none}

.field-hint{
  text-align:center;font-size:11px;color:var(--text3);
  padding:4px 14px;letter-spacing:0.3px;flex-shrink:0;
}

/* INPUT BAR */
.input-bar{
  background:var(--bg-card);border-top:1px solid var(--border);
  padding:10px 14px;flex-shrink:0;
}
.ib-row{display:flex;gap:14px;flex-wrap:wrap;align-items:flex-start}
.ib-sec{flex-shrink:0}
.sec-lbl{font-size:9px;font-weight:800;letter-spacing:1.2px;text-transform:uppercase;color:var(--text3);margin-bottom:5px}
.chips{display:flex;gap:3px;flex-wrap:wrap}
.chip{
  padding:4px 10px;border-radius:16px;border:1px solid var(--border2);
  background:none;color:var(--text2);font-size:11px;font-weight:700;
  font-family:var(--font);cursor:pointer;transition:all 100ms;
}
.chip:active{transform:scale(0.93)}
.chip.on,.chip:hover{background:var(--accent-dim);border-color:var(--accent);color:var(--accent)}

/* ZONE GRID */
.zone-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2px;width:72px}
.zone-cell{
  aspect-ratio:1;border:1px solid var(--border2);border-radius:3px;
  background:var(--bg-raised);cursor:pointer;transition:all 100ms;
}
.zone-cell:hover{background:var(--accent-dim);border-color:var(--accent)}
.zone-cell.on{background:var(--accent);border-color:var(--accent)}

.ib-sec-grow{flex:1;min-width:150px}
.other-btns{display:flex;gap:3px;flex-wrap:wrap}
.o-btn{
  padding:4px 9px;border-radius:14px;border:1px solid var(--border2);
  background:none;color:var(--text2);font-size:11px;font-weight:700;
  font-family:var(--font);cursor:pointer;transition:all 100ms;
}
.o-btn:active{transform:scale(0.93)}
.o-btn.walk:hover{border-color:var(--purple);color:var(--purple);background:rgba(167,139,250,.08)}
.o-btn.k:hover{border-color:var(--red);color:var(--red);background:rgba(245,101,101,.08)}
.o-btn.hbp:hover{border-color:var(--orange);color:var(--orange);background:rgba(251,146,60,.08)}
.o-btn.sac:hover{border-color:var(--yellow);color:var(--yellow);background:rgba(246,194,62,.08)}
.o-btn.dp:hover{border-color:var(--text2);color:var(--text);background:var(--bg-hover)}

.sb-row{display:flex;gap:4px;margin-top:5px}
.sb-btn{
  padding:3px 8px;border-radius:6px;border:1px solid var(--border2);
  background:none;color:var(--text3);font-size:10px;font-weight:700;
  font-family:var(--font);cursor:pointer;transition:all 100ms;
}
.sb-btn:hover{border-color:var(--yellow);color:var(--yellow)}
.sb-btn:active{transform:scale(0.93)}

/* RIGHT PANEL */
.pnl-right{
  background:var(--bg-card);border-left:1px solid var(--border);
  display:flex;flex-direction:column;overflow:hidden;
}
.tabs{display:flex;border-bottom:1px solid var(--border);flex-shrink:0}
.tab{
  flex:1;padding:11px 8px;text-align:center;font-size:11px;font-weight:700;
  color:var(--text3);cursor:pointer;transition:all 100ms;
  border-bottom:2px solid transparent;display:flex;align-items:center;
  justify-content:center;gap:4px;
}
.tab.on{color:var(--accent);border-bottom-color:var(--accent)}
.tab-body{flex:1;overflow-y:auto;padding:10px}
.tab-pnl{display:none}
.tab-pnl.on{display:block}

/* RECORDS */
.rec-hd{display:flex;justify-content:space-between;align-items:center;margin-bottom:7px}
.rec-count{font-size:10px;color:var(--text3)}
.rec-item{
  display:flex;align-items:flex-start;gap:8px;padding:8px;
  border-radius:7px;border:1px solid var(--border);margin-bottom:4px;
  background:var(--bg-raised);position:relative;transition:border-color 100ms;
}
.rec-item:hover{border-color:var(--border2)}
.badge{
  padding:2px 6px;border-radius:4px;font-size:10px;font-weight:800;
  white-space:nowrap;flex-shrink:0;
}
.b-hit{background:rgba(45,212,160,.12);color:var(--green)}
.b-2b{background:rgba(75,140,245,.12);color:var(--accent)}
.b-3b{background:rgba(246,194,62,.12);color:var(--yellow)}
.b-hr{background:rgba(245,101,101,.12);color:var(--red)}
.b-out{background:rgba(67,76,94,.2);color:var(--text3)}
.b-walk{background:rgba(167,139,250,.12);color:var(--purple)}
.b-k{background:rgba(245,101,101,.12);color:var(--red)}
.b-hbp{background:rgba(251,146,60,.12);color:var(--orange)}
.b-other{background:rgba(67,76,94,.15);color:var(--text2)}
.rec-info{flex:1;min-width:0}
.rec-player{font-size:11px;font-weight:700}
.rec-detail{font-size:10px;color:var(--text3);margin-top:1px}
.rec-del{
  position:absolute;top:7px;right:7px;background:none;border:none;
  color:var(--text3);cursor:pointer;font-size:12px;padding:1px 3px;
  border-radius:3px;transition:all 100ms;
}
.rec-del:hover{color:var(--red);background:rgba(245,101,101,.1)}

/* STATS */
.stat-card{
  background:var(--bg-raised);border:1px solid var(--border);
  border-radius:var(--r);padding:12px;margin-bottom:8px;
}
.sc-title{font-size:9px;font-weight:800;letter-spacing:1.2px;text-transform:uppercase;color:var(--text3);margin-bottom:8px}
.stat-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:6px}
.stat-it{text-align:center}
.stat-v{font-family:var(--mono);font-size:18px;font-weight:700;color:var(--text)}
.stat-l{font-size:9px;color:var(--text3);margin-top:1px}
.stat-v-sm{font-family:var(--mono);font-size:15px;font-weight:700;color:var(--text)}

/* DIRECTION BARS */
.dir-chart{display:flex;gap:6px;align-items:flex-end;height:52px;margin-bottom:6px}
.dir-bar-w{flex:1;display:flex;flex-direction:column;align-items:center;gap:3px}
.dir-bar{width:100%;border-radius:3px 3px 0 0;min-height:3px;transition:height 500ms cubic-bezier(.4,0,.2,1)}
.dir-pull{background:var(--red)}
.dir-ctr{background:var(--green)}
.dir-oppo{background:var(--accent)}
.dir-pct{font-family:var(--mono);font-size:11px;font-weight:700}
.dir-lbl{font-size:9px;color:var(--text3);text-align:center}

/* DONUT */
.donut-row{display:flex;align-items:center;gap:12px}
.donut-cvs{width:72px;height:72px;flex-shrink:0}
.legend{flex:1}
.leg-item{display:flex;align-items:center;gap:5px;margin-bottom:3px;font-size:10px;color:var(--text2)}
.leg-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}
.leg-pct{margin-left:auto;font-family:var(--mono);font-size:10px;color:var(--text)}

/* PLAYER STATS TABLE */
.ps-row{
  display:flex;align-items:center;gap:6px;padding:5px 0;
  border-bottom:1px solid var(--border);font-size:11px;
}
.ps-num{font-family:var(--mono);font-size:10px;color:var(--text3);width:18px;text-align:right}
.ps-name{flex:1;font-weight:700}
.ps-avg{font-family:var(--mono);font-size:12px;font-weight:700}
.ps-ab{font-size:10px;color:var(--text3)}

/* MODAL */
.overlay{
  position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:200;
  display:flex;align-items:center;justify-content:center;
  opacity:0;pointer-events:none;transition:opacity 180ms;
}
.overlay.show{opacity:1;pointer-events:all}
.modal{
  background:var(--bg-card);border:1px solid var(--border2);border-radius:var(--r2);
  padding:22px;width:min(320px,92vw);
  transform:translateY(10px);transition:transform 180ms;box-shadow:var(--shadow);
}
.overlay.show .modal{transform:translateY(0)}
.modal-title{font-size:15px;font-weight:800;margin-bottom:4px}
.modal-sub{font-size:11px;color:var(--text3);margin-bottom:14px}
.hit-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:6px;margin-bottom:12px}
.hit-btn{
  padding:12px 8px;border-radius:9px;border:1px solid var(--border2);
  background:var(--bg-raised);color:var(--text);font-size:12px;font-weight:700;
  font-family:var(--font);cursor:pointer;transition:all 100ms;text-align:center;
}
.hit-btn:active{transform:scale(0.95)}
.hb-hit{border-color:var(--green)}
.hb-hit:hover{background:rgba(45,212,160,.1)}
.hb-2b{border-color:var(--accent)}
.hb-2b:hover{background:var(--accent-dim)}
.hb-3b{border-color:var(--yellow)}
.hb-3b:hover{background:rgba(246,194,62,.1)}
.hb-hr{border-color:var(--red)}
.hb-hr:hover{background:rgba(245,101,101,.1)}
.hb-fly{border-color:var(--text3)}
.hb-fly:hover{background:var(--bg-hover)}
.hb-grd{border-color:var(--text3)}
.hb-grd:hover{background:var(--bg-hover)}
.rbi-row{display:flex;align-items:center;gap:8px;margin-bottom:14px}
.rbi-lbl{font-size:11px;color:var(--text2);font-weight:700}
.rbi-val{font-family:var(--mono);font-size:16px;font-weight:700;min-width:24px;text-align:center}
.rbi-btn{
  width:26px;height:26px;border:1px solid var(--border2);background:var(--bg-raised);
  color:var(--text2);border-radius:6px;cursor:pointer;font-size:14px;
  display:flex;align-items:center;justify-content:center;transition:all 90ms;
  font-family:var(--mono);
}
.rbi-btn:hover{border-color:var(--accent);color:var(--accent)}
.rbi-btn:active{transform:scale(0.88)}

/* TOAST */
.toast{
  position:fixed;bottom:20px;left:50%;
  transform:translateX(-50%) translateY(16px);
  background:var(--bg-raised);border:1px solid var(--border2);
  border-radius:10px;padding:10px 16px;font-size:12px;font-weight:700;
  z-index:300;opacity:0;transition:all 280ms;display:flex;
  align-items:center;gap:10px;white-space:nowrap;box-shadow:var(--shadow);
  pointer-events:none;
}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0);pointer-events:all}
.toast-undo{
  color:var(--accent);cursor:pointer;font-weight:800;border:none;
  background:none;font-family:var(--font);font-size:12px;padding:0;
}

/* ONBOARDING */
.ob-overlay{
  position:fixed;inset:0;background:rgba(0,0,0,.88);z-index:500;
  display:flex;align-items:center;justify-content:center;
}
.ob-card{
  background:var(--bg-card);border:1px solid var(--border2);
  border-radius:var(--r2);padding:28px 24px;width:min(360px,92vw);
  text-align:center;box-shadow:var(--shadow);
}
.ob-icon{font-size:40px;margin-bottom:12px}
.ob-step{font-size:9px;font-weight:800;letter-spacing:1.5px;color:var(--text3);text-transform:uppercase;margin-bottom:6px}
.ob-title{font-size:20px;font-weight:900;margin-bottom:10px;line-height:1.3}
.ob-desc{font-size:13px;color:var(--text2);line-height:1.7;margin-bottom:20px}
.ob-dots{display:flex;justify-content:center;gap:5px;margin-bottom:18px}
.ob-dot{width:5px;height:5px;border-radius:50%;background:var(--border2);transition:all 200ms}
.ob-dot.on{background:var(--accent);width:16px;border-radius:3px}

/* LOAD MODAL ITEMS */
.load-item{
  padding:9px 11px;border:1px solid var(--border);border-radius:8px;
  margin-bottom:5px;cursor:pointer;background:var(--bg-raised);
  transition:border-color 100ms;
}
.load-item:hover{border-color:var(--accent)}
.load-item-title{font-size:12px;font-weight:700}
.load-item-date{font-size:10px;color:var(--text3);margin-top:2px}

/* MOBILE */
@media(max-width:720px){
  html,body{overflow:auto}
  .layout{
    grid-template-columns:1fr;grid-template-rows:auto;
    height:auto;overflow:visible;
  }
  .pnl-left{
    display:none /* replaced by mobile batter row */
  }
  .pnl-right{border-left:none;border-top:1px solid var(--border);height:auto;min-height:360px}
  .canvas-wrap{width:min(380px,100%)}
  .field-wrap{padding:8px}
  .mob-batter{
    display:flex;overflow-x:auto;gap:5px;padding:8px 12px;
    background:var(--bg-card);border-bottom:1px solid var(--border);
    scrollbar-width:none;flex-shrink:0;
  }
  .mob-batter::-webkit-scrollbar{display:none}
  .mob-chip{
    flex-shrink:0;padding:5px 10px;border-radius:16px;
    border:1px solid var(--border2);background:var(--bg-raised);
    color:var(--text2);font-size:11px;font-weight:700;cursor:pointer;
    transition:all 100ms;white-space:nowrap;font-family:var(--font);
  }
  .mob-chip.on{border-color:var(--accent);color:var(--accent);background:var(--accent-dim)}
  .mob-chip:active{transform:scale(0.95)}
  .hdr{gap:8px}
  .brand-tag{display:none}
  .scoreboard{padding:5px 10px;gap:8px}
  .sc-val{font-size:17px}
  .inn-sel{display:none}
  .hdr-actions{gap:5px}
}
@media(min-width:721px){
  .mob-batter{display:none}
}
</style>
</head>
<body>

<!-- ONBOARDING -->
<div class="ob-overlay" id="obOverlay">
