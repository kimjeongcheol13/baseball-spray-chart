// ==================== CANVAS ====================
let FS=440,fCtx,hCtx,oCtx,fC,hC,oC;

function initCanvas(){
  const w=document.getElementById('cwrap');
  FS=w.clientWidth;
  [fC,hC,oC]=['fldCanvas','hitCanvas','ovrCanvas'].map(id=>{
    const c=document.getElementById(id);
    c.width=FS;c.height=FS;return c;
  });
  fCtx=fC.getContext('2d');
  hCtx=hC.getContext('2d');
  oCtx=oC.getContext('2d');
  drawField();
  fC.addEventListener('click',onFClick);
  fC.addEventListener('touchend',e=>{
    e.preventDefault();
    const t=e.changedTouches[0];
    const r=fC.getBoundingClientRect();
    const sx=FS/r.width,sy=FS/r.height;
    onFClick({clientX:t.clientX,clientY:t.clientY,rect:r,sx,sy,touch:true});
  },{passive:false});
  window.addEventListener('resize',()=>{initCanvas();redrawHits()});
}

function drawField(){
  const ctx=fCtx,S2=FS,cx=S2/2,cy=S2;
  ctx.clearRect(0,0,S2,S2);

  // BG gradient
  const bg=ctx.createRadialGradient(cx,cy,0,cx,cy,S2);
  bg.addColorStop(0,'#0a1a0c');bg.addColorStop(0.55,'#081508');bg.addColorStop(1,'#050e07');
  ctx.beginPath();ctx.arc(cx,cy,S2*0.97,-Math.PI,0);ctx.lineTo(cx,cy);ctx.closePath();
  ctx.fillStyle=bg;ctx.fill();

  // Warning track
  ctx.beginPath();
  ctx.arc(cx,cy,S2*0.97,-Math.PI,0);
  ctx.arc(cx,cy,S2*0.89,0,-Math.PI,true);
  ctx.closePath();ctx.fillStyle='#150e06';ctx.fill();

  // Infield dirt
  ctx.beginPath();ctx.arc(cx,cy,S2*0.41,-Math.PI,0);ctx.lineTo(cx,cy);ctx.closePath();
  ctx.fillStyle='#1a1106';ctx.fill();

  // Infield grass
  ctx.beginPath();ctx.arc(cx,cy,S2*0.33,-Math.PI,0);ctx.lineTo(cx,cy);ctx.closePath();
  ctx.fillStyle='#0b1a0d';ctx.fill();

  // Foul lines
  ctx.strokeStyle='rgba(255,255,255,0.18)';ctx.lineWidth=1.5;
  ctx.beginPath();ctx.moveTo(cx,cy);ctx.lineTo(cx-S2*0.97,cy);ctx.stroke();
  ctx.beginPath();ctx.moveTo(cx,cy);ctx.lineTo(cx+S2*0.97,cy);ctx.stroke();

  // Zone dividers
  ctx.setLineDash([3,5]);ctx.strokeStyle='rgba(255,255,255,0.08)';ctx.lineWidth=1;
  [[Math.PI*0.72],[Math.PI*0.28]].forEach(([a])=>{
    ctx.beginPath();ctx.moveTo(cx,cy);
    ctx.lineTo(cx+Math.cos(a+Math.PI)*S2*0.97,cy+Math.sin(a+Math.PI)*S2*0.97);ctx.stroke();
  });
  ctx.setLineDash([]);

  // Outfield arc
  ctx.beginPath();ctx.arc(cx,cy,S2*0.89,-Math.PI,0);
  ctx.strokeStyle='rgba(255,255,255,0.1)';ctx.lineWidth=1;ctx.stroke();

  // Diamond
  const br=S2*0.42;
  const bases=[
    [cx,cy-br*0.65],
    [cx-br*0.46,cy-br*0.33],
    [cx+br*0.46,cy-br*0.33]
  ];
  ctx.fillStyle='rgba(255,255,255,0.35)';
  bases.forEach(([bx,by])=>{
    ctx.save();ctx.translate(bx,by);ctx.rotate(Math.PI/4);
    ctx.fillRect(-5.5,-5.5,11,11);ctx.restore();
  });

  // Home plate
  ctx.fillStyle='rgba(255,255,255,0.5)';
  ctx.beginPath();ctx.moveTo(cx,cy-7);ctx.lineTo(cx+6,cy-2);
  ctx.lineTo(cx+6,cy+3);ctx.lineTo(cx-6,cy+3);ctx.lineTo(cx-6,cy-2);
  ctx.closePath();ctx.fill();

  // Pitcher mound
  ctx.beginPath();ctx.arc(cx,cy-S2*0.32,7,0,Math.PI*2);
  ctx.fillStyle='#1a1106';ctx.fill();
  ctx.strokeStyle='rgba(255,255,255,0.2)';ctx.lineWidth=1;ctx.stroke();

  // Zone labels
  ctx.fillStyle='rgba(255,255,255,0.12)';
  ctx.font=`bold ${Math.floor(S2*0.025)}px 'JetBrains Mono', monospace`;
  ctx.textAlign='center';
  ctx.fillText('LF',cx-S2*0.32,cy-S2*0.58);
  ctx.fillText('CF',cx,cy-S2*0.72);
  ctx.fillText('RF',cx+S2*0.32,cy-S2*0.58);

  // Direction labels
  const dl=Math.floor(S2*0.019);
  ctx.font=`700 ${dl}px 'Noto Sans KR', sans-serif`;
  ctx.fillStyle='rgba(245,101,101,0.22)';ctx.fillText('당겨치기',cx-S2*0.23,cy-S2*0.37);
  ctx.fillStyle='rgba(45,212,160,0.22)';ctx.fillText('센터',cx,cy-S2*0.45);
  ctx.fillStyle='rgba(75,140,245,0.22)';ctx.fillText('밀어치기',cx+S2*0.23,cy-S2*0.37);

  // Base path lines
  ctx.strokeStyle='rgba(255,255,255,0.12)';ctx.lineWidth=1;
  const bps=[[cx,cy],[cx-br*0.46,cy-br*0.33],[cx,cy-br*0.65],[cx+br*0.46,cy-br*0.33],[cx,cy]];
  ctx.beginPath();bps.forEach(([x,y],i)=>i===0?ctx.moveTo(x,y):ctx.lineTo(x,y));ctx.stroke();
}

function onFClick(e){
  let x,y;
  const rect=e.rect||fC.getBoundingClientRect();
  const sx=e.sx||(FS/rect.width),sy=e.sy||(FS/rect.height);
  x=(e.clientX-rect.left)*sx;
  y=(e.clientY-rect.top)*sy;

  const cx=FS/2,cy=FS;
  const dx=x-cx,dy=y-cy,dist=Math.sqrt(dx*dx+dy*dy);
  if(dy>0||dist>FS*0.97) return;

  // Overlay dot
  oCtx.clearRect(0,0,FS,FS);
  oCtx.beginPath();oCtx.arc(x,y,10,0,Math.PI*2);
  oCtx.fillStyle='rgba(255,255,255,0.2)';oCtx.fill();
  oCtx.beginPath();oCtx.arc(x,y,4.5,0,Math.PI*2);
  oCtx.fillStyle='#fff';oCtx.fill();
  oC.classList.add('show');

  // Compute direction
  const ang=Math.atan2(dy,dx); // -PI..0
  const deg=(ang+Math.PI)*180/Math.PI; // 0=left, 90=center, 180=right
  let dir;
  if(deg<54) dir='LF';
  else if(deg<78) dir='LC';
  else if(deg<102) dir='CF';
  else if(deg<126) dir='RC';
  else dir='RF';

  const estFt=Math.round(dist/FS*450);

  S.pending={x:x/FS,y:y/FS,deg,dir,ft:estFt};
  S.rbi=0;
  document.getElementById('rbiVal').textContent='0';
  document.getElementById('hitSub').textContent=`방향: ${dir} · 추정거리: ${estFt}ft`;
  openOverlay('hitOverlay');
}

function recHit(res){
  if(!S.batter){showToast('타자를 먼저 선택하세요',false,false);closeHit();return}
  const r={
    id:Date.now(),bid:S.batter.id,bname:S.batter.name,bnum:S.batter.num,
    res,pt:S.pt,zone:S.zone,rbi:S.rbi,
    x:S.pending.x,y:S.pending.y,deg:S.pending.deg,dir:S.pending.dir,ft:S.pending.ft,
    inn:document.getElementById('innSel').value,
    ts:new Date().toLocaleTimeString('ko-KR',{hour:'2-digit',minute:'2-digit'})
  };
  S.abs.push(r);S.totalRBI+=S.rbi;
  drawDot(r);closeHit();updateAll();
  showToast(`#${r.bnum} ${r.bname} — ${res}${r.rbi>0?' ('+r.rbi+'타점)':''}`,true);
}

function recOther(res){
  if(!S.batter){showToast('타자를 먼저 선택하세요',false,false);return}
  const r={
    id:Date.now(),bid:S.batter.id,bname:S.batter.name,bnum:S.batter.num,
